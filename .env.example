# Local development defaults. Copy to `.env` for local/self-host testing.
PORT=4317
CODEX_PET_LEAGUE_URL=http://localhost:4317
CODEX_PET_DEPLOYMENT_ENV=local
CODEX_PET_STATE_PATH=./data/league-state.json
CODEX_PET_SESSION_TOKEN=
CODEX_PET_ACCOUNT_ID=acct_demo

# Local auth defaults. Keep dev code/header fallback off unless you are explicitly testing them.
CODEX_PET_AUTH_PROVIDER=local_dev
CODEX_PET_AUTH_DEV_CODE=false
CODEX_PET_ALLOW_DEV_ACCOUNT_HEADER=false
CODEX_PET_ADMIN_EMAIL_ALLOWLIST=
CODEX_PET_COOKIE_SECURE=false
CODEX_PET_PUBLIC_BASE_URL=http://localhost:4317

# Email-code auth placeholders. Production alpha target: Resend.
CODEX_PET_EMAIL_PROVIDER=
CODEX_PET_EMAIL_WEBHOOK_URL=
CODEX_PET_AUTH_WEBHOOK_SECRET=
CODEX_PET_EMAIL_WEBHOOK_SECRET=
CODEX_PET_RESEND_FROM_EMAIL=
CODEX_PET_RESEND_FROM_NAME=Codex Pet League
CODEX_PET_RESEND_REPLY_TO=
CODEX_PET_RESEND_API_KEY=
CODEX_PET_SES_REGION=
CODEX_PET_SES_FROM_EMAIL=
CODEX_PET_SES_FROM_NAME=Codex Pet League
CODEX_PET_SES_REPLY_TO=
CODEX_PET_SES_CONFIGURATION_SET=
CODEX_PET_SES_ACCESS_KEY_ID=
CODEX_PET_SES_SECRET_ACCESS_KEY=
CODEX_PET_SES_SESSION_TOKEN=
CODEX_PET_PASSKEY_PROVIDER=false
CODEX_PET_PASSKEY_VERIFY_URL=
CODEX_PET_PASSKEY_RP_ID=localhost
CODEX_PET_OAUTH_ISSUER=
CODEX_PET_OAUTH_AUTHORIZE_URL=
CODEX_PET_OAUTH_CLIENT_ID=
CODEX_PET_OAUTH_REDIRECT_URI=http://localhost:4317
CODEX_PET_OAUTH_VERIFY_URL=

# League signing secrets. Replace every value outside local development.
CODEX_PET_BRIDGE_SECRET=change-me
CODEX_PET_BRIDGE_ATTESTATION_SECRET=change-me-too
CODEX_PET_REPLAY_SIGNING_SECRET=change-me-replay
CODEX_PET_OPS_JOB_INTERVAL_MS=60000

# Local storage defaults. Production target: Render Postgres.
CODEX_PET_STORAGE_DRIVER=json
CODEX_PET_SQLITE_PATH=./data/league-state.sqlite
CODEX_PET_SQLITE_SNAPSHOT_RETENTION=500
CODEX_PET_POSTGRES_URL=
CODEX_PET_POSTGRES_SNAPSHOT_RETENTION=500
CODEX_PET_POSTGRES_SSL=false
CODEX_PET_POSTGRES_SSL_REJECT_UNAUTHORIZED=true

# Local asset defaults. Production target: Cloudflare R2 + custom domain.
CODEX_PET_ASSET_STORAGE=local_fs
CODEX_PET_ASSET_ROOT=./data/assets
CODEX_PET_ASSET_CDN_BASE_URL=
CODEX_PET_S3_ENDPOINT=
CODEX_PET_S3_BUCKET=
CODEX_PET_S3_REGION=auto
CODEX_PET_S3_ACCESS_KEY_ID=
CODEX_PET_S3_SECRET_ACCESS_KEY=

# Local realtime/request guard defaults. Production target: Render Key Value.
CODEX_PET_REALTIME_BUS=local
CODEX_PET_REALTIME_CHANNEL=codex-pet-league:events
CODEX_PET_REQUEST_GUARD=local
CODEX_PET_REQUEST_GUARD_NAMESPACE=codex-pet-league
CODEX_PET_DISTRIBUTED_LOCK=local
CODEX_PET_LOCK_NAMESPACE=codex-pet-league
CODEX_PET_LOCK_TTL_MS=30000
CODEX_PET_REDIS_URL=

# Moderation placeholders. Production target: OpenAI Moderation API.
OPENAI_API_KEY=
CODEX_PET_MODERATION_PROVIDER=
CODEX_PET_MODERATION_MODEL=omni-moderation-latest
CODEX_PET_MODERATION_FAIL_MODE=review

# Render production template. Keep commented in git; set these in Render env vars.
# NODE_ENV=production
# CODEX_PET_DEPLOYMENT_ENV=production
# PORT=4317
# CODEX_PET_PUBLIC_BASE_URL=https://league.<domain>
# CODEX_PET_COOKIE_SECURE=true
# CODEX_PET_AUTH_PROVIDER=email_code
# CODEX_PET_AUTH_DEV_CODE=false
# CODEX_PET_ALLOW_DEV_ACCOUNT_HEADER=false
# CODEX_PET_ADMIN_EMAIL_ALLOWLIST=owner@example.com
# CODEX_PET_EMAIL_PROVIDER=resend
# CODEX_PET_RESEND_FROM_EMAIL=no-reply@league.<domain>
# CODEX_PET_RESEND_FROM_NAME=Codex Pet League
# CODEX_PET_RESEND_REPLY_TO=support@<domain>
# CODEX_PET_RESEND_API_KEY=<resend-api-key>
# CODEX_PET_PASSKEY_PROVIDER=false
# CODEX_PET_PASSKEY_VERIFY_URL=
# CODEX_PET_PASSKEY_RP_ID=league.<domain>
# CODEX_PET_OAUTH_ISSUER=
# CODEX_PET_OAUTH_AUTHORIZE_URL=
# CODEX_PET_OAUTH_CLIENT_ID=
# CODEX_PET_OAUTH_REDIRECT_URI=
# CODEX_PET_OAUTH_VERIFY_URL=
# CODEX_PET_STORAGE_DRIVER=postgres
# CODEX_PET_POSTGRES_URL=<render-postgres-internal-url>
# CODEX_PET_POSTGRES_SSL=false
# CODEX_PET_REALTIME_BUS=redis
# CODEX_PET_REQUEST_GUARD=redis
# CODEX_PET_DISTRIBUTED_LOCK=redis
# CODEX_PET_REDIS_URL=<render-key-value-internal-url>
# CODEX_PET_ASSET_STORAGE=s3_compatible
# CODEX_PET_S3_ENDPOINT=https://<cloudflare-account-id>.r2.cloudflarestorage.com
# CODEX_PET_S3_BUCKET=<r2-bucket-name>
# CODEX_PET_S3_REGION=auto
# CODEX_PET_S3_ACCESS_KEY_ID=<r2-access-key-id>
# CODEX_PET_S3_SECRET_ACCESS_KEY=<r2-secret-access-key>
# CODEX_PET_ASSET_CDN_BASE_URL=https://assets.<domain>
# OPENAI_API_KEY=<openai-api-key>
# CODEX_PET_MODERATION_PROVIDER=openai
# CODEX_PET_MODERATION_MODEL=omni-moderation-latest
# CODEX_PET_MODERATION_FAIL_MODE=review
# CODEX_PET_BRIDGE_SECRET=<strong-secret>
# CODEX_PET_BRIDGE_ATTESTATION_SECRET=<strong-secret>
# CODEX_PET_REPLAY_SIGNING_SECRET=<strong-secret>
