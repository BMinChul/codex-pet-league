{
  "name": "codex-pet-league",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "bin": {
    "codexpet": "./src/cli/index.js"
  },
  "scripts": {
    "cli": "node src/cli/index.js",
    "mcp": "node src/mcp/codex-pet-mcp.cjs",
    "start": "node src/server/index.js",
    "dev": "node --watch src/server/index.js",
    "test": "node --test test/*.test.js",
    "test:runtime": "node scripts/runtime-smoke.mjs",
    "test:abuse": "node scripts/abuse-smoke.mjs",
    "test:storage": "node scripts/storage-smoke.mjs",
    "test:load": "node scripts/load-smoke.mjs",
    "test:browser": "playwright test test/browser-smoke.spec.mjs --browser=chromium --workers=1 --output=runs/playwright",
    "balance:sim": "node scripts/balance-sim.mjs",
    "verify:loop": "node scripts/verify-loop.mjs",
    "ops:check": "node scripts/ops-check.mjs",
    "admin:bootstrap": "node scripts/bootstrap-admin.mjs",
    "prod:check": "node scripts/production-check.mjs",
    "backup": "node scripts/backup-state.mjs",
    "audit:summary": "node scripts/audit-summary.mjs",
    "ops:rehash": "node scripts/rehash-state-chains.mjs",
    "cost:check": "node scripts/cost-guard.mjs",
    "incident:pack": "node scripts/incident-pack.mjs",
    "healthcheck": "node scripts/healthcheck.mjs",
    "db:schema:check": "node scripts/postgres-schema-check.mjs",
    "db:postgres:migrate": "node scripts/postgres-migrate.mjs",
    "db:migrate": "node scripts/migrate-json-to-sqlite.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1"
  },
  "dependencies": {
    "pg": "^8.20.0"
  }
}
